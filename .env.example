APP_NAME=Unified Library API
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

DATABASE_URL=mysql+pymysql://library:library123@mysql:3306/unified_library?charset=utf8mb4
REDIS_URL=redis://redis:6379/0
ADMIN_TOKEN=change-me
AUTO_CREATE_TABLES=false

MAX_SOURCES=5
DIRECT_LINK_TTL_SECONDS=1800
DIRECT_LINK_LOCK_TIMEOUT_SECONDS=30
DIRECT_LINK_WAIT_SECONDS=15
DIRECT_LINK_RETRY_BASE_SECONDS=30

SCAN_POLL_INTERVAL_SECONDS=5
SCAN_BATCH_SIZE=200
SOURCE_REQUEST_TIMEOUT_SECONDS=20

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_NAME=unified_library_files
OPENSEARCH_TIMEOUT_SECONDS=10
SEARCH_SYNC_BATCH_SIZE=500

PREHEAT_ENABLED=true
PREHEAT_POLL_INTERVAL_SECONDS=120
PREHEAT_LIMIT=50
PREHEAT_MIN_HOT_SCORE=1
PREHEAT_REFRESH_BEFORE_SECONDS=300
